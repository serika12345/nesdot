{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Frontend Dev Server",
      "type": "shell",
      "command": "nix",
      "args": ["develop", "-c", "zsh", "-lc", "pnpm dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "ready in",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "Run Tauri Dev",
      "type": "shell",
      "command": "nix",
      "args": ["develop", "-c", "zsh", "-lc", "pnpm start"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "ready in",
          "endsPattern": "ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Format Check",
      "type": "shell",
      "command": "nix",
      "args": ["develop", "-c", "zsh", "-lc", "pnpm format:check"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Verify",
      "type": "shell",
      "command": "nix",
