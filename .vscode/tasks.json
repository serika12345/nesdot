{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Frontend Dev Server",
            "type": "shell",
            "command": "pnpm",
            "args": ["dev"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "ready in",
                    "endsPattern": "ready in"
                }
            }
        },
        {
            "label": "Run Tauri Dev",
            "type": "shell",
            "command": "pnpm",
            "args": ["start"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
