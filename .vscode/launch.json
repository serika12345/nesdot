{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Frontend (Chrome, 1420)",
      "url": "http://localhost:1420",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "Run Frontend Dev Server"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Launch Tauri Desktop",
      "command": "echo Tauri dev is started by the Run Tauri Dev task.",
      "preLaunchTask": "Run Tauri Dev"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Attach Frontend (Chrome, 1420)",
      "url": "http://localhost:1420",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Launch Tauri Desktop + Attach Frontend",
      "configurations": ["Attach Frontend (Chrome, 1420)"],
      "preLaunchTask": "Run Tauri Dev",
      "stopAll": true
    }
  ]
}
