{
  "name": "nesdot",
  "type": "module",
  "private": true,
  "productName": "nesdot",
  "version": "0.2.1",
  "packageManager": "pnpm@10.32.1",
  "description": "An NES screen emulator built with Tauri and React.",
  "scripts": {
    "icons:sync": "bash ./scripts/sync-icons.sh",
    "dev": "pnpm icons:sync && vite",
    "dev:tauri": "node scripts/ensure-tauri-dev-server.mjs",
    "start": "pnpm icons:sync && tauri dev",
    "build": "pnpm icons:sync && tsc --noEmit && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:licenses": "node scripts/verify-licenses.mjs && node scripts/verify-system-libraries.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "verify:system-libraries": "node scripts/verify-system-libraries.mjs",
    "verify:cve": "node scripts/verify-cves.mjs",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "typecheck:safety": "tsc -p tsconfig.type-safety.json --noEmit",
    "package": "pnpm icons:sync && tauri build",
    "make": "pnpm icons:sync && tauri build",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:install": "playwright install chromium",
    "doctor:wsl": "node scripts/doctor-wsl.mjs",
    "nix:check-pnpm-deps-hash": "node scripts/sync-flake-pnpm-deps-hash.mjs --check",
    "nix:sync-pnpm-deps-hash": "node scripts/sync-flake-pnpm-deps-hash.mjs",
    "test:e2e": "playwright test",
    "test:e2e:console": "playwright test e2e/console.spec.ts --project=chromium",
    "test:e2e:headed": "playwright test e2e/console.spec.ts --project=chromium --headed",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck:safety && pnpm verify:security && pnpm test",
    "verify:rust": "pnpm rust:fmt:check && pnpm rust:check && pnpm rust:lint && pnpm rust:test",
    "verify:ui": "pnpm verify && pnpm test:e2e:console",
    "verify:full": "pnpm verify:ui && pnpm test:e2e",
    "release:auto": "node scripts/release-automation.mjs",
    "release:auto:dry-run": "node scripts/release-automation.mjs --dry-run",
    "tauri": "tauri"
  },
  "keywords": [],
  "author": {
    "name": "paseri3739",
    "email": "tael43@icloud.com"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^5.0.0": "5.0.5",
      "yaml@^1.10.0": "1.10.3"
    }
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pigment-css/vite-plugin": "0.0.30",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "hoist-non-react-statics": "^3.3.2",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react-is": "^19.2.5",
    "typescript": "~5.8.3",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-pigment-css": "7.3.9",
    "@pigment-css/react": "0.0.30",
    "@radix-ui/react-menubar": "^1.1.16",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "fabric": "^7.2.0",
    "fp-ts": "^2.16.11",
    "idb-keyval": "^6.2.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  }
}
