{
  "name": "nesdot",
  "type": "module",
  "private": true,
  "productName": "nesdot",
  "version": "1.0.0",
  "description": "An NES screen emulator built with Tauri and React.",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "node scripts/ensure-tauri-dev-server.mjs",
    "start": "tauri dev",
    "build": "tsc --noEmit && vite build",
    "package": "tauri build",
    "make": "tauri build",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:console": "playwright test e2e/console.spec.ts --project=chromium",
    "test:e2e:headed": "playwright test e2e/console.spec.ts --project=chromium --headed",
    "tauri": "tauri"
  },
  "keywords": [],
  "author": {
    "name": "paseri3739",
    "email": "tael43@icloud.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "fp-ts": "^2.16.11",
    "idb-keyval": "^6.2.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  }
}
