{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nesdot",
  "version": "0.2.0",
  "identifier": "com.paseri3739.nesdot",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nesdot",
        "width": 1300,
        "height": 1000
      }
    ],
    "security": {
      "headers": {
        "X-Content-Type-Options": "nosniff"
      },
      "freezePrototype": true,
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "blob:", "data:"],
        "font-src": ["'self'"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
        "object-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'self'"],
        "frame-ancestors": ["'none'"]
      },
      "devCsp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "blob:", "data:"],
        "font-src": ["'self'"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:1420",
          "http://127.0.0.1:1420",
          "http://[::1]:1420",
          "ws://localhost:1421",
          "ws://127.0.0.1:1421",
          "ws://[::1]:1421"
        ],
        "object-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'self'"],
        "frame-ancestors": ["'none'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzNzNERjBFMUFGQjNDNwpSV1RIczYvaDhEMDNDRU1Kc0NNYjJiRGlLWXhDTnVsQUxMeUJtelg2SHE2WWZOVzQyb3NVRHE0cAo=",
      "endpoints": [
        "https://github.com/paseri3739/nesdot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
