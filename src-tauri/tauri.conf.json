{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nesdot",
  "version": "0.1.7",
  "identifier": "com.paseri3739.nesdot",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nesdot",
        "width": 1300,
        "height": 1000
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzNzNERjBFMUFGQjNDNwpSV1RIczYvaDhEMDNDRU1Kc0NNYjJiRGlLWXhDTnVsQUxMeUJtelg2SHE2WWZOVzQyb3NVRHE0cAo=",
      "endpoints": [
        "https://github.com/paseri3739/nesdot/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
